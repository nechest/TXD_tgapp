{
  "name": "postgresql-exam-prep",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start": "node bot/server.mjs",
    "serve": "node bot/server.mjs",
